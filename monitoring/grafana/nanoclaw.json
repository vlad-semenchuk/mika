            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "lineWidth": 0,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" }
