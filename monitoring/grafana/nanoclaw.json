      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(nanoclaw_messages_received_total[24h]))",
          "legendFormat": "messages",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
