      ]
    },
    {
      "id": 7,
      "title": "Task Success Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 5, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.8, "color": "yellow" },
              { "value": 0.95, "color": "green" }
            ]
          },
          "noValue": "N/A"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(nanoclaw_task_execution_result_total{status=\"success\"}[24h]) / (increase(nanoclaw_task_execution_result_total{status=\"success\"}[24h]) + increase(nanoclaw_task_execution_result_total{status=\"error\"}[24h]))",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
