{
  "uid": "nanoclaw-v1",
  "title": "NanoClaw",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["nanoclaw"],
  "panels": [
    {
      "id": 1,
      "title": "Agent Invocations / min",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(nanoclaw_agent_invocation_total[5m]) * 60",
          "legendFormat": "invocations/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Containers",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nanoclaw_containers_active",
          "legendFormat": "active containers",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Container Failures / min",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(nanoclaw_container_failure_total[5m]) * 60",
          "legendFormat": "failures/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Heap Memory Used",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "heap used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "event loop lag",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Container Duration p95",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(nanoclaw_container_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 duration",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Agent Duration p95",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(nanoclaw_agent_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 duration",
          "refId": "A"
        }
      ]
    }
  ]
}
